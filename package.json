{
    "name": "godot-launcher",
    "private": true,
    "version": "1.10.0-beta.1",
    "packageManager": "npm@11.16.0",
    "description": "Godot Launcher is a companion app for managing Godot projects with per-project editor settings.",
    "keywords": [
        "godot",
        "launcher",
        "per-project editor settings"
    ],
    "type": "module",
    "main": "dist-electron/main.js",
    "author": {
        "name": "Mario Debono - godotlauncher.org",
        "email": "mario@godotlauncher.org",
        "url": "https://godotlauncher.org"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/godotlauncher/launcher.git"
    },
    "bugs": {
        "url": "https://github.com/godotlauncher/launcher/issues"
    },
    "homepage": "https://godotlauncher.org",
    "engines": {
        "node": ">=24.13.0"
    },
    "scripts": {
        "dev": "npm-run-all --race --parallel dev:electron dev:react",
        "dev:electron": "npm run transpile:electron && cross-env NODE_ENV=development electron .",
        "dev:react": "vite",
        "build": "tsc && vite build",
        "transpile:electron": "tsc --project main/tsconfig.build.json && tsc-alias -p main/tsconfig.build.json",
        "lint": "biome check",
        "lint:fix": "biome check --write",
        "lint:report": "biome check --reporter=summary --diagnostic-level=error",
        "format": "biome format --write",
        "preview": "vite preview",
        "build:sources": "npm run build && npm run transpile:electron",
        "dist:mac": "npm run build:sources && electron-builder --config electron-builder-config.ts --mac",
        "dist:linux": "npm run build:sources && electron-builder --config electron-builder-config.ts --linux",
        "dist:win": "npm run build:sources && electron-builder --config electron-builder-config.ts --win ",
        "dist:win:publish": "npm run build:sources && electron-builder --config electron-builder-config.ts --win --publish always",
        "dist": "npm run build:sources && electron-builder --config electron-builder-config.ts --mac --win --linux",
        "test:e2e": "playwright test",
        "test:unit": "vitest main/src renderer/src",
        "app:dir": "electron-builder --dir",
        "app:dist": "electron-builder",
        "postinstall": "electron-builder install-app-deps",
        "changelog": "auto-changelog",
        "changelog:unreleased": "auto-changelog --unreleased",
        "doc:screenshots": "playwright test e2e/documentationScreenshot.spec.ts"
    },
    "auto-changelog": {
        "tagPattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$",
        "ignoreCommitPattern": "[R|r]elease|[c|C]hore|changelog|update changelog|updated changelog|update CHANGELOG"
    },
    "dependencies": {
        "@mariodebono/di": "^1.0.1",
        "@mariodebono/di-config": "^1.0.2",
        "clsx": "^2.1.1",
        "decompress": "^4.2.1",
        "electron-log": "^5.4.4",
        "electron-updater": "^6.8.3",
        "i18next": "^26.3.1",
        "i18next-fs-backend": "^2.6.6",
        "javascript-time-ago": "^2.6.4",
        "jsonc-parser": "^3.3.1",
        "lucide-react": "^1.17.0",
        "mustache": "^4.2.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.8",
        "react-router": "^8.0.1",
        "reflect-metadata": "^0.2.2",
        "semver": "^7.8.2",
        "which": "^7.0.0",
        "yargs": "^18.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@babel/helpers": "^7.29.7",
        "@biomejs/biome": "^2.4.16",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4.3.0",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.3.0",
        "@types/decompress": "^4.2.7",
        "@types/mustache": "^4.2.6",
        "@types/node": "^24.13.0",
        "@types/react": "^19.2.16",
        "@types/react-dom": "^19.2.3",
        "@types/semver": "^7.7.1",
        "@types/which": "^3.0.4",
        "@types/yargs": "^17.0.35",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.7",
        "auto-changelog": "^2.6.0",
        "cross-env": "^10.1.0",
        "daisyui": "^5.5.20",
        "dotenv": "^17.4.2",
        "dotenv-expand": "^13.0.0",
        "electron": "^41.7.1",
        "electron-builder": "^26.8.1",
        "npm-run-all": "^4.1.5",
        "postcss": "^8.5.15",
        "prettier": "^3.8.3",
        "sharp": "^0.34.5",
        "tailwindcss": "^4.3.0",
        "tsc-alias": "^1.8.17",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.7"
    }
}
