{
    "compilerOptions": {
        // decorators
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,

        "strict": true,
        "target": "ESNext",
        "module": "NodeNext",
        "paths": {
            "@shared/contracts": ["../shared/src/contracts/index.d.ts"]
            // Add runtime @shared paths when needed.
        },
        "rootDir": "./src",
        "outDir": "../dist-electron",
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.cts",
        "../shared/src/contracts/**/*.d.ts"
    ]
}
