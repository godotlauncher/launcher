{
    "extends": "../tsconfig.node.json",
    "compilerOptions": {
        "composite": false,
        "incremental": false,
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "@playwright/test"],
        "resolveJsonModule": true,
        "paths": {
            "@shared": ["../shared/src/index.d.ts"],
            "@shared/*": [
                "../shared/src/*/index.d.ts",
                "../shared/src/*"
            ]
        }
    },
    "include": [
        "./**/*.ts",
        "../playwright.config.ts",
        "../shared/src/**/*.d.ts"
    ],
    "exclude": ["../node_modules"]
}
