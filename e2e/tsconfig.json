{
    "extends": "../tsconfig.node.json",
    "compilerOptions": {
        "composite": false,
        "incremental": false,
        "noEmit": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["node", "@playwright/test"],
        "resolveJsonModule": true,
        "paths": {
            "@shared/contracts": ["../shared/src/contracts/index.d.ts"]
        }
    },
    "include": [
        "./**/*.ts",
        "../playwright.config.ts",
        "../shared/src/contracts/**/*.d.ts"
    ],
    "exclude": ["../node_modules"]
}
